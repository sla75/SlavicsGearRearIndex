<resources xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://developer.garmin.com/downloads/connect-iq/resources.xsd">

    <properties>
        <property id="property_version" type="string">0.0.0</property>
        <property id="property_showteeth" type="boolean">true</property>
        <property id="property_nightMode" type="boolean">false</property>
        <property id="property_colorMode" type="number">0</property>
    </properties>

    <settings>
        <setting propertyKey="@Properties.property_version" title="@Strings.property_version_title">
            <settingConfig type="alphaNumeric" readonly="true"/>
        </setting>
        <setting propertyKey="@Properties.property_showteeth" title="@Strings.property_showteeth_title">
            <settingConfig type="boolean" required="true" />
        </setting>
        <setting propertyKey="@Properties.property_nightMode" title="@Strings.property_nightMode_title">
            <settingConfig type="boolean" required="true" />
        </setting>
        <setting propertyKey="@Properties.property_colorMode" title="@Strings.property_colorMode_title">
            <settingConfig type="list">
                <listEntry value="0">Black and White</listEntry>
                <listEntry value="1">Blue</listEntry>
                <listEntry value="2">Green</listEntry>
                <listEntry value="3">Pink</listEntry>
            </settingConfig>
        </setting>
    </settings>
</resources>
